# ============================================
# KINKER BASEL - Environment Variables
# ============================================

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Stripe Payment Configuration
# ============================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Eventfrog Configuration
# ============================================
# Get API key from: https://eventfrog.ch/en/organizer/api/
# Use the PUBLIC API key for displaying events on the website

EVENTFROG_API_KEY=your_eventfrog_public_api_key

# Optional: Filter events by organizer ID(s), comma-separated
# Find your organizer ID on /eventfrog-debug after setting the API key
EVENTFROG_ORGANIZER_IDS=your_organizer_id

# Optional: Filter events by organizer name (fallback if ID doesn't work)
EVENTFROG_ORGANIZER_NAME=kinker

# Optional: Eventfrog API Base URL (default: https://api.eventfrog.net)
# EVENTFROG_API_URL=https://api.eventfrog.net

# ============================================
# Resend Email Configuration
# ============================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=KINKER Basel

# ============================================
# Session Security
# ============================================
SESSION_SECRET=your_random_32_char_secret_min

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=https://knkr.ch
NODE_ENV=development
