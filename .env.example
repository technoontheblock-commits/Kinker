# ============================================
# KINKER BASEL - Environment Variables
# ============================================

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# SumUp Payment Configuration
# ============================================
# SumUp API Key (from SumUp Developer Dashboard)
# Get it from: https://developer.sumup.com/
SUMUP_API_KEY=supp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SumUp Merchant Code (your merchant identifier)
# Found in SumUp Dashboard → Profile → Merchant Code
SUMUP_MERCHANT_CODE=your_merchant_code

# SumUp Webhook Secret (for verifying webhooks - optional)
# SUMUP_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP settings for sending emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=noreply@kinkerbasel.ch

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
