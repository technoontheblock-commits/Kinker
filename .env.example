# ============================================
# KINKER BASEL - Environment Variables
# ============================================

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Stripe Payment Configuration
# ============================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Eventfrog Configuration
# ============================================
# Get API key from: https://eventfrog.ch/en/organizer/api/
# Two options available:
# 1. Public API: Read - For displaying events on website
# 2. Organizer API: Read - For sales data, ticket buyers, etc.

EVENTFROG_API_KEY=your_eventfrog_api_key
EVENTFROG_ORGANIZER_ID=your_organizer_id

# Optional: Eventfrog API Base URL (default: https://api.eventfrog.net)
# EVENTFROG_API_URL=https://api.eventfrog.net

# ============================================
# Resend Email Configuration
# ============================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=KINKER Basel

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=https://knkr.ch
NODE_ENV=development
